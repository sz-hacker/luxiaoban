{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/hb/:path*", "destination": "/api/hb/:path*" },
    { "source": "/hb-cloud/:path*", "destination": "/api/hb-cloud/:path*" },
    { "source": "/pdf-proxy/:path*", "destination": "/api/pdf-proxy/:path*" },
    { "source": "/_proxy-health", "destination": "/api/health" }
  ]
}
